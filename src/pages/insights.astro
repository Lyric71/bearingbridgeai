---
import Layout from '../layouts/Layout.astro';

const pieces = [
  {
    n: '01',
    category: 'Method',
    title: '12 NotebookLM Prompts That Do Real Work',
    summary:
      'Most people give NotebookLM lazy prompts and get book reports back. Here are twelve our team uses that pull real work out of it instead.',
    href: '/insights/12-notebooklm-prompts-that-do-real-work',
    status: 'June 2026',
  },
];
---

<Layout
  title="Insights — The East-West Briefing | BearingBridge AI"
  description="The East-West Briefing and method pieces by Cyril Drouin: what moved in AI on both sides of the world, and what it means for operators."
>
  <!-- ============================== HERO ============================== -->
  <section class="meridians grain relative overflow-hidden bg-cream">
    <div class="relative z-10 mx-auto max-w-5xl px-5 pb-20 pt-40 sm:px-8 lg:pt-52">
      <p class="kicker" data-reveal>Insights</p>
      <h1 class="font-display mt-6 text-4xl leading-[1.08] tracking-tight text-ink sm:text-6xl lg:text-7xl" data-reveal style="--reveal-delay: 1">
        Reading the water on both <span class="accent-word">sides</span>.
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-relaxed text-ink/70" data-reveal style="--reveal-delay: 2">
        A monthly East-West Briefing and one method piece per month. Written by Cyril Drouin —
        no ghostwriters, no hype.
      </p>
    </div>
  </section>

  <!-- ========================= ARTICLE INDEX ========================= -->
  <section class="bg-paper">
    <div class="mx-auto max-w-5xl px-5 py-24 sm:px-8 lg:py-32">
      <ol class="divide-y divide-ink/10 border-y border-ink/10" data-reveal-group>
        {pieces.map((p) => (
          <li class="group relative transition-colors duration-300 hover:bg-cream-soft" data-reveal>
            <a href={p.href} class="block py-12 sm:px-8">
              <div class="flex flex-col gap-6 sm:flex-row sm:gap-10">
                <span class="numeral text-6xl sm:text-7xl">{p.n}</span>
                <div class="flex-1">
                  <div class="flex flex-wrap items-center gap-3">
                    <span class="border border-accent/40 px-3 py-1 text-[0.65rem] font-semibold uppercase tracking-kicker text-accent">{p.category}</span>
                    <span class="text-xs uppercase tracking-kicker text-ink/45">{p.status}</span>
                  </div>
                  <h2 class="font-display mt-4 max-w-2xl text-2xl leading-snug text-ink transition-colors duration-300 group-hover:text-accent-deep sm:text-3xl">
                    {p.title}
                  </h2>
                  <p class="mt-3 max-w-2xl leading-relaxed text-ink/65">{p.summary}</p>
                  <p class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-accent">
                    Read the piece <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
                  </p>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>
</Layout>
