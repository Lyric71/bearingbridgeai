---
import Layout from '../layouts/Layout.astro';
import CompassRose from '../components/CompassRose.astro';

const regions = ['North Asia', 'Southeast Asia', 'Middle East', 'Europe'];
---

<Layout
  title="Contact — start with a conversation | BearingBridge AI"
  description="30 minutes. Bring your messiest AI question. If we're not the right partner, we'll say so and point you somewhere better."
>
  <section class="meridians grain relative overflow-hidden bg-cream">
    <CompassRose
      class="pointer-events-none absolute -right-28 -top-20 hidden h-[26rem] w-[26rem] text-ink/10 lg:block"
    />
    <div class="relative z-10 mx-auto max-w-7xl px-5 pb-24 pt-40 sm:px-8 lg:pb-32 lg:pt-52">
      <div class="grid gap-16 lg:grid-cols-12">
        <!-- copy column -->
        <div class="lg:col-span-5" data-reveal="left">
          <p class="kicker">Contact</p>
          <h1 class="font-display mt-6 text-4xl leading-[1.08] tracking-tight text-ink sm:text-5xl lg:text-6xl">
            Start with a <span class="accent-word">conversation</span>.
          </h1>
          <p class="mt-7 max-w-prose text-lg leading-relaxed text-ink/70">
            30 minutes. Bring your messiest AI question. If we’re not the right partner, we’ll say so —
            and point you somewhere better.
          </p>

          <dl class="mt-12 space-y-6 border-t border-ink/15 pt-8">
            <div>
              <dt class="text-xs uppercase tracking-kicker text-ink/50">Direct email</dt>
              <dd class="mt-1">
                <a href="mailto:hello@bearingbridge.ai" class="link-rule font-display text-xl text-ink">hello@bearingbridge.ai</a>
              </dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-kicker text-ink/50">Entities</dt>
              <dd class="mt-1 font-display text-xl text-ink">Hong Kong · Shanghai</dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-kicker text-ink/50">Coverage</dt>
              <dd class="mt-1 text-ink/70">North Asia · Southeast Asia · Middle East · Europe</dd>
            </div>
          </dl>
        </div>

        <!-- form column -->
        <div class="lg:col-span-7" data-reveal="right">
          <form id="contact-form" class="border border-ink/15 bg-paper p-8 sm:p-10" novalidate>
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="cf-name" class="text-xs font-semibold uppercase tracking-kicker text-ink/60">Name *</label>
                <input id="cf-name" name="name" type="text" class="field mt-2" required autocomplete="name" />
              </div>
              <div>
                <label for="cf-email" class="text-xs font-semibold uppercase tracking-kicker text-ink/60">Work email *</label>
                <input id="cf-email" name="email" type="email" class="field mt-2" required autocomplete="email" />
              </div>
              <div>
                <label for="cf-company" class="text-xs font-semibold uppercase tracking-kicker text-ink/60">Company</label>
                <input id="cf-company" name="company" type="text" class="field mt-2" autocomplete="organization" />
              </div>
              <div>
                <label for="cf-role" class="text-xs font-semibold uppercase tracking-kicker text-ink/60">Role</label>
                <input id="cf-role" name="role" type="text" class="field mt-2" autocomplete="organization-title" />
              </div>
            </div>

            <fieldset class="mt-7">
              <legend class="text-xs font-semibold uppercase tracking-kicker text-ink/60">Region</legend>
              <div class="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-4">
                {regions.map((r) => (
                  <label class="region-chip cursor-pointer border border-ink/20 px-3 py-2.5 text-center text-sm text-ink/70 transition-all duration-200 has-checked:border-accent has-checked:bg-accent has-checked:text-cream hover:border-ink/50">
                    <input type="radio" name="region" value={r} class="sr-only" />
                    {r}
                  </label>
                ))}
              </div>
            </fieldset>

            <div class="mt-7">
              <label for="cf-message" class="text-xs font-semibold uppercase tracking-kicker text-ink/60">What’s on your mind? *</label>
              <textarea id="cf-message" name="message" rows="5" class="field mt-2 resize-y" required></textarea>
            </div>

            <!-- honeypot -->
            <div class="absolute left-[-9999px]" aria-hidden="true">
              <label for="cf-website">Website</label>
              <input id="cf-website" name="website" type="text" tabindex="-1" autocomplete="off" />
            </div>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
              <button type="submit" class="btn btn-primary" id="cf-submit">
                <span id="cf-submit-label">Send — we reply within 2 business days</span>
                <span class="btn-arrow">→</span>
              </button>
              <p class="text-xs text-ink/45">No 14-field qualification gauntlet. This is the whole form.</p>
            </div>

            <p id="cf-status" class="mt-5 hidden border-l-2 pl-4 text-sm" role="status" aria-live="polite"></p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const status = document.getElementById('cf-status');
    const submit = document.getElementById('cf-submit') as HTMLButtonElement | null;
    const label = document.getElementById('cf-submit-label');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.reportValidity() || !submit || !status || !label) return;

      const fd = new FormData(form);
      const role = String(fd.get('role') ?? '').trim();
      const region = String(fd.get('region') ?? '').trim();
      const lines: string[] = [];
      if (role) lines.push(`Role: ${role}`);
      if (region) lines.push(`Region: ${region}`);
      if (lines.length) lines.push('');
      lines.push(String(fd.get('message') ?? ''));

      submit.disabled = true;
      label.textContent = 'Sending…';
      status.classList.add('hidden');

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: fd.get('name'),
            email: fd.get('email'),
            company: fd.get('company'),
            message: lines.join('\n'),
            website: fd.get('website'),
          }),
        });
        const data = await res.json();
        if (!res.ok || data.error) throw new Error(data.error ?? 'Failed');

        form.reset();
        status.className = 'mt-5 border-l-2 border-success pl-4 text-sm text-ink/80';
        status.textContent = 'Received. We read everything personally — you’ll hear back within 2 business days.';
        label.textContent = 'Sent ✓';
      } catch {
        status.className = 'mt-5 border-l-2 border-accent pl-4 text-sm text-ink/80';
        status.textContent = 'Something went wrong sending your message. Email us directly at hello@bearingbridge.ai.';
        label.textContent = 'Send — we reply within 2 business days';
        submit.disabled = false;
      }
    });
  </script>
</Layout>
