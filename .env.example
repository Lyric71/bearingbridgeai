# WaveSpeed AI — text-to-image generation (https://wavespeed.ai)
WAVESPEED_API_KEY=

# Resend — transactional email (https://resend.com/api-keys)
RESEND_API_KEY=

# Recipient address for the contact form
CONTACT_TO_EMAIL=

# Optional sender override. Defaults to the Resend free-tier sender
# (BearingBridge AI <onboarding@resend.dev>). Set this after verifying a
# custom domain in the Resend dashboard, e.g. "BearingBridge AI <noreply@bearingbridge.ai>"
CONTACT_FROM_EMAIL=
