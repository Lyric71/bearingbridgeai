---
import Layout from '../layouts/Layout.astro';

const timeline = [
  { year: '1998', text: 'Based in China. Two decades and counting inside the world’s fastest-moving digital market.' },
  { year: '2003', text: 'Founded one of China’s first eCommerce and digital agencies; led it to acquisition by Publicis.' },
  { year: '2015', text: 'CEO, Publicis Commerce & Performance Marketing, China and North Asia — global FMCG, luxury, beauty and pharmaceutical clients.' },
  { year: '2026', text: 'BearingBridge AI. Same playbook as 2003: honest guides win the wave.' },
];

const trust = [
  {
    title: 'Entities where we operate',
    body: 'Legal entities in Hong Kong and Shanghai; regional coverage across North Asia, Southeast Asia, the Middle East, and Europe.',
  },
  {
    title: 'Your data, your choice',
    body: 'Your data never transits to China unless you explicitly choose it — e.g., for a China-hosted deployment serving your China operations.',
  },
  {
    title: 'Paperwork before promises',
    body: 'NDAs and DPAs before any engagement; regulatory mapping (EU AI Act, China AI measures, ME frameworks) is part of every Assessment.',
  },
];
---

<Layout
  title="About — senior judgment, two ecosystems, no hype | BearingBridge AI"
  description="Founded by Cyril Drouin: 25 years building digital and commerce operations across Asia and Europe. Entities in Hong Kong and Shanghai. Your data never transits to China unless you choose it."
>
  <!-- ============================== HERO ============================== -->
  <section class="meridians grain relative overflow-hidden bg-cream">
    <div class="relative z-10 mx-auto max-w-5xl px-5 pb-20 pt-40 text-center sm:px-8 lg:pt-52">
      <p class="kicker justify-center" data-reveal>About</p>
      <h1 class="font-display mt-6 text-4xl leading-[1.08] tracking-tight text-ink sm:text-6xl lg:text-7xl" data-reveal style="--reveal-delay: 1">
        Senior judgment, two ecosystems, no <span class="accent-word">hype</span>.
      </h1>
    </div>
  </section>

  <!-- ========================= FOUNDER ========================= -->
  <section class="bg-paper">
    <div class="mx-auto max-w-7xl px-5 py-24 sm:px-8 lg:py-32">
      <div class="grid gap-14 lg:grid-cols-12">
        <div class="lg:col-span-5" data-reveal="left">
          <div class="meridians grain sticky top-28 flex aspect-[4/5] items-center justify-center border border-ink/15 bg-cream">
            <span class="font-display text-9xl italic text-accent">CD</span>
            <span class="absolute bottom-5 left-0 right-0 text-center text-xs uppercase tracking-kicker text-ink/45">
              Cyril Drouin · Founder
            </span>
          </div>
        </div>
        <div class="lg:col-span-7">
          <div data-reveal>
            <p class="kicker">The founder</p>
            <h2 class="font-display mt-5 text-3xl leading-tight text-ink sm:text-4xl">Cyril Drouin</h2>
            <p class="mt-6 max-w-prose text-lg leading-relaxed text-ink/70">
              Twenty-five years building digital and commerce operations across Asia and Europe. A
              regular speaker and trainer on the Chinese digital ecosystem worldwide.
            </p>
            <p class="mt-5 max-w-prose border-l-2 border-accent pl-5 font-display text-xl italic leading-relaxed text-ink/80">
              “The AI wave looks exactly like the eCommerce wave of 2003: enormous, real, and badly
              served by hype merchants. The companies that won then were the ones with honest guides.
              Same now.”
            </p>
          </div>

          <!-- timeline -->
          <ol class="relative mt-12 space-y-10 border-l border-dashed border-ink/30 pl-8" data-reveal-group>
            {timeline.map((tl) => (
              <li class="relative" data-reveal>
                <span class="absolute -left-[2.45rem] top-1.5 h-[9px] w-[9px] bg-accent" aria-hidden="true"></span>
                <p class="numeral text-3xl">{tl.year}</p>
                <p class="mt-2 max-w-prose leading-relaxed text-ink/70">{tl.text}</p>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== THE CHINA ADVANTAGE ===================== -->
  <section class="grain relative overflow-hidden bg-cream">
    <div class="relative z-10 mx-auto max-w-7xl px-5 py-24 sm:px-8 lg:py-32">
      <div class="grid items-center gap-14 lg:grid-cols-2">
        <div data-reveal="left">
          <div class="border border-ink/15 bg-paper p-2 sm:p-3">
            <img
              src="/Images/world-meridians.png"
              alt="Line-drawn map of the eastern and western hemispheres"
              class="block w-full"
              width="1600"
              height="900"
              loading="lazy"
            />
          </div>
        </div>
        <div data-reveal="right">
          <p class="kicker">The China advantage</p>
          <h2 class="font-display mt-5 text-3xl leading-tight text-ink sm:text-4xl">
            We don’t bridge two AI worlds. We <span class="accent-word">choose</span> from both.
          </h2>
          <p class="mt-6 max-w-prose leading-relaxed text-ink/70">
            Most consultancies see the AI landscape through one window — the Western one. Operating
            from Shanghai and Hong Kong as well as Europe, we evaluate Chinese frontier models (Qwen,
            DeepSeek, Kimi and what ships next quarter) alongside Western ones, on your data, for
            your regions.
          </p>
          <p class="mt-4 max-w-prose font-display text-lg italic text-ink/75">
            Often the result surprises clients — in capability, and especially in cost.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== TRUST & STRUCTURE ===================== -->
  <section class="bg-paper">
    <div class="mx-auto max-w-7xl px-5 py-24 sm:px-8 lg:py-28">
      <div class="max-w-2xl" data-reveal>
        <p class="kicker">Trust &amp; structure</p>
        <h2 class="font-display mt-5 text-3xl leading-tight text-ink sm:text-4xl">
          Built for the questions you <span class="accent-word">should</span> ask.
        </h2>
      </div>
      <div class="mt-12 grid gap-6 lg:grid-cols-3" data-reveal-group>
        {trust.map((tr, i) => (
          <div class="card-lift corner-tick border border-ink/15 bg-paper p-8" data-reveal>
            <span class="numeral text-3xl">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="font-display mt-4 text-xl text-ink">{tr.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink/65">{tr.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========================= CTA ========================= -->
  <section class="bg-ink text-cream">
    <div class="mx-auto max-w-3xl px-5 py-20 text-center sm:px-8 lg:py-24" data-reveal>
      <h2 class="font-display text-3xl leading-tight sm:text-4xl">
        Talk to a person who’s done this <span class="accent-word">before</span>.
      </h2>
      <div class="mt-8">
        <a href="/contact" class="btn btn-primary" data-magnetic>
          <span>Book a call with Cyril</span>
          <span class="btn-arrow">→</span>
        </a>
      </div>
    </div>
  </section>
</Layout>
